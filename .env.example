GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
VERTEX_GEMINI_MODEL=gemini-2.5-flash
VERTEX_GEMINI_TEMPERATURE=0.2
VERTEX_EMBEDDING_MODEL=text-embedding-005
VERTEX_EMBEDDING_DIMENSIONS=768
DRIVE_VERTEX_DEFAULT_TOP_K=5
DRIVE_VERTEX_CONVERSATION_MAX_TURNS=6

# Share the Drive folder with this service account if you want non-interactive auth.
# GOOGLE_DRIVE_SERVICE_ACCOUNT_FILE=/absolute/path/to/service-account.json

# Otherwise use a Desktop OAuth client downloaded from Google Cloud Console.
GOOGLE_DRIVE_OAUTH_CLIENT_SECRET_FILE=/absolute/path/to/oauth-client-secret.json
GOOGLE_DRIVE_TOKEN_FILE=.secrets/google-drive-token.json

# Optional defaults for the CLI. GOOGLE_DRIVE_FOLDER_ID can also be chosen during `drive-vertex sync`.
GOOGLE_DRIVE_FOLDER_ID=your-drive-folder-id
DRIVE_VERTEX_INDEX_DIR=.cache/drive-vertex-index
